# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.aizet-next/
/home/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# 암호화 키 백업(대표님 수동 백업 후 삭제 대상) — git에 절대 커밋 금지
/REGISTRY_ENC_KEY_BACKUP.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 런타임에 생성되는 사용자 데이터 — git에 커밋하지 않음(용량·개인정보)
/data/render-output/
/data/super-editor-files/
/tmp/

# SQLite 데이터베이스 — 런타임 데이터라 git에 커밋하지 않음(스키마는 src/lib/db.ts가 소스)
/data/aizet.db
/data/aizet.db-shm
/data/aizet.db-wal

# 명부·사업장 SQLite DB 및 백업 — 런타임 데이터라 커밋 금지(스키마는 소스, 데이터는 제외)
/data/registry.db
/data/registry.db-shm
/data/registry.db-wal
/data/members/
/data/backups/
/.preview-next/
/data/learn-public/
/data/incoming/
