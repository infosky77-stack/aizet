{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/myspace/layout,_N_T_/myspace/page,_N_T_/myspace"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/myspace/__PAGE__",
    "/myspace",
    "/_index",
    "/_head"
  ]
}