{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/print/layout,_N_T_/print/quote/layout,_N_T_/print/quote/page,_N_T_/print/quote"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/print/quote/__PAGE__",
    "/print/quote",
    "/print",
    "/_index",
    "/_head"
  ]
}